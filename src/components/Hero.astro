---
import type { SiteData, UiData } from '../types';

interface Props {
	site: SiteData;
	ui: UiData;
}

const { site, ui } = Astro.props;
---

<section class="hero section">
	<div class="container hero__grid">
		<div class="hero__copy">
			<p class="badge">{site.hero.badge}</p>
			<h1>{site.hero.headline}</h1>
			<p class="hero__sub">{site.hero.subheadline}</p>
			<div class="hero__actions">
				<a class="btn btn-primary" href="#products">{ui.ctaPrimary}</a>
				<a class="btn btn-secondary" href="#order">{ui.ctaOrder}</a>
			</div>
		</div>
		<div class="hero__visual card" aria-hidden="true">
			<div class="hero__visual-inner">
				<div class="hero__loaf"></div>
				<div class="hero__cookie"></div>
				<div class="hero__steam hero__steam--1"></div>
				<div class="hero__steam hero__steam--2"></div>
			</div>
		</div>
	</div>
</section>

<section class="about section">
	<div class="container about__inner">
		<h2>{site.about.title}</h2>
		{site.about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
	</div>
</section>

<style>
	.hero {
		padding-top: clamp(2rem, 6vw, 4rem);
	}

	.hero__grid {
		display: grid;
		gap: 2.5rem;
		align-items: center;
	}

	.hero__sub {
		font-size: 1.15rem;
		color: var(--color-muted);
		max-width: 34rem;
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.5rem;
	}

	.hero__visual {
		min-height: 18rem;
		background: linear-gradient(145deg, #fff8ef 0%, #ead9bf 100%);
		position: relative;
	}

	.hero__visual-inner {
		position: relative;
		height: 100%;
		min-height: 18rem;
	}

	.hero__loaf {
		position: absolute;
		left: 18%;
		bottom: 18%;
		width: 42%;
		aspect-ratio: 1.4;
		border-radius: 42% 42% 18% 18%;
		background: linear-gradient(180deg, #c68642 0%, #8b5a2b 100%);
		box-shadow: inset 0 -12px 0 rgba(0, 0, 0, 0.08);
	}

	.hero__loaf::before {
		content: '';
		position: absolute;
		inset: 18% 12% auto;
		height: 35%;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.12);
	}

	.hero__cookie {
		position: absolute;
		right: 16%;
		top: 22%;
		width: 28%;
		aspect-ratio: 1;
		border-radius: 50%;
		background: radial-gradient(circle at 35% 30%, #e8c896, #b8864d);
		box-shadow: inset 0 0 0 6px rgba(139, 90, 43, 0.15);
	}

	.hero__cookie::after {
		content: '';
		position: absolute;
		inset: 22%;
		background:
			radial-gradient(circle, #4a2f18 18%, transparent 19%) 20% 30% / 22% 22%,
			radial-gradient(circle, #4a2f18 18%, transparent 19%) 55% 45% / 18% 18%,
			radial-gradient(circle, #4a2f18 18%, transparent 19%) 35% 65% / 16% 16%;
		background-repeat: no-repeat;
	}

	.hero__steam {
		position: absolute;
		width: 0.5rem;
		height: 2.5rem;
		border-radius: 999px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.7), transparent);
		opacity: 0.7;
	}

	.hero__steam--1 {
		left: 32%;
		top: 18%;
		transform: rotate(-8deg);
	}

	.hero__steam--2 {
		left: 40%;
		top: 14%;
		transform: rotate(6deg);
		height: 3rem;
	}

	.about {
		padding-top: 0;
	}

	.about__inner {
		max-width: 42rem;
		padding: 2rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		box-shadow: var(--shadow-sm);
	}

	.about__inner p:last-child {
		margin-bottom: 0;
	}

	@media (min-width: 900px) {
		.hero__grid {
			grid-template-columns: 1.05fr 0.95fr;
		}
	}
</style>
