---
import type { Product, UiData } from '../types';
import { orderMailto } from '../utils/i18n';

interface Props {
	product: Product;
	ui: UiData;
	categoryLabel: string;
}

const { product, ui, categoryLabel } = Astro.props;
const mailto = orderMailto(
	product.orderSubject,
	`${ui.orderBody}\n\n${product.name}\n${ui.orderFulfillmentLine}`,
	ui.orderEmail,
);
---

<article class="product-card card">
	<div class="product-card__media">
		<img src={product.image} alt={product.name} width="800" height="600" loading="lazy" />
		<span class="product-card__category">{categoryLabel}</span>
	</div>
	<div class="product-card__body">
		<h3>{product.name}</h3>
		<p class="product-card__tagline">{product.tagline}</p>
		<p class="product-card__note">{ui.pricingNote}</p>
		<div class="product-card__included">
			<h4>{ui.includedLabel}</h4>
			<ul class="pill-list">
				{product.included.map((item) => <li>{item}</li>)}
			</ul>
		</div>
		<a class="btn btn-primary product-card__order" href={mailto}>{ui.orderButton}</a>
	</div>
</article>

<style>
	.product-card {
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.product-card__media {
		position: relative;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background: var(--color-surface-2);
	}

	.product-card__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.product-card__category {
		position: absolute;
		top: 0.85rem;
		left: 0.85rem;
		padding: 0.3rem 0.65rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.92);
		border: 1px solid var(--color-border);
		font-size: 0.78rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--color-crust);
	}

	.product-card__body {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		padding: 1.25rem;
		flex: 1;
	}

	.product-card__tagline {
		color: var(--color-muted);
		margin: 0;
	}

	.product-card__note {
		font-size: 0.92rem;
		font-weight: 600;
		color: var(--color-wheat);
		margin: 0;
	}

	.product-card__included h4 {
		font-family: var(--font-sans);
		font-size: 0.82rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--color-muted);
		margin: 0 0 0.35rem;
	}

	.product-card__order {
		margin-top: auto;
		width: 100%;
	}
</style>
