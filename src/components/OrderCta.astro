---
import type { UiData } from '../types';
import { orderMailto } from '../utils/i18n';

interface Props {
	ui: UiData;
}

const { ui } = Astro.props;
const mailto = orderMailto(
	'NANA Bakery order',
	`${ui.orderBody}\n\n${ui.orderFulfillmentLine}`,
	ui.orderEmail,
);
---

<section id="order" class="section order-cta">
	<div class="container">
		<div class="order-cta__panel card">
			<div>
				<h2>{ui.sections.order}</h2>
				<p>{ui.sections.orderSubtitle}</p>
				<p class="order-cta__note">{ui.pricingNote}</p>
			</div>
			<div class="order-cta__actions">
				<a class="btn btn-primary" href={mailto}>{ui.ctaOrder}</a>
				<a class="order-cta__email" href={`mailto:${ui.orderEmail}`}>{ui.orderEmail}</a>
			</div>
		</div>
	</div>
</section>

<style>
	.order-cta__panel {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		padding: clamp(1.5rem, 4vw, 2.5rem);
		background: linear-gradient(135deg, #ffffff 0%, #f3ece1 100%);
	}

	.order-cta__panel p {
		color: var(--color-muted);
		margin-bottom: 0.5rem;
	}

	.order-cta__note {
		font-weight: 600;
		color: var(--color-wheat) !important;
	}

	.order-cta__actions {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.75rem;
	}

	.order-cta__email {
		font-weight: 600;
	}

	@media (min-width: 768px) {
		.order-cta__panel {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
		}
	}
</style>
