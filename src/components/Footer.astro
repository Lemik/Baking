---
import type { UiData } from '../types';

interface Props {
	ui: UiData;
	brand: string;
}

const { ui, brand } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="container site-footer__inner">
		<div>
			<strong>{brand}</strong>
			<p>{ui.footer.tagline}</p>
			<p>{ui.footer.delivery}</p>
			<p>{ui.footer.pickup}</p>
		</div>
		<p class="site-footer__copy">© {year} {brand}</p>
	</div>
</footer>

<style>
	.site-footer {
		padding: 2rem 0 2.5rem;
		border-top: 1px solid var(--color-border);
		background: rgba(255, 255, 255, 0.35);
	}

	.site-footer__inner {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		color: var(--color-muted);
	}

	.site-footer strong {
		display: block;
		font-family: var(--font-display);
		font-size: 1.1rem;
		color: var(--color-crust);
		margin-bottom: 0.35rem;
	}

	.site-footer p {
		margin: 0 0 0.35rem;
		font-size: 0.95rem;
	}

	.site-footer__copy {
		font-size: 0.85rem;
	}
</style>
