---
import type { Product, SiteData, UiData } from '../types';

interface Props {
	site: SiteData;
	ui: UiData;
	products: Product[];
}

const { site, ui, products } = Astro.props;
const lemonLoaf = products.find((p) => p.id === 'lemon-loaf');
const poppyRoll = products.find((p) => p.id === 'poppy-seed-roll');
---

<section class="hero section">
	<div class="container hero__grid">
		<div class="hero__copy">
			<p class="hero__badge badge">
				<span class="hero__badge-dot" aria-hidden="true"></span>
				{site.hero.badge}
			</p>
			<h1>{site.hero.headline}</h1>
			<p class="hero__sub">{site.hero.subheadline}</p>
			<div class="hero__actions">
				<a class="btn btn-primary" href="#products">{ui.ctaPrimary}</a>
				<a class="btn btn-secondary" href="#order">{ui.ctaOrder}</a>
			</div>
		</div>

		{lemonLoaf && poppyRoll && (
			<div class="hero__visual">
				<div class="hero__photo hero__photo--main card">
					<img
						src={lemonLoaf.image}
						alt={lemonLoaf.name}
						width="800"
						height="600"
						fetchpriority="high"
						decoding="async"
					/>
				</div>
				<div class="hero__photo hero__photo--accent card">
					<img
						src={poppyRoll.image}
						alt={poppyRoll.name}
						width="800"
						height="600"
						loading="eager"
						decoding="async"
					/>
				</div>
				<div class="hero__glow" aria-hidden="true"></div>
			</div>
		)}
	</div>
</section>

<section class="about section">
	<div class="container about__inner">
		<p class="about__eyebrow" aria-hidden="true">🌾</p>
		<h2>{site.about.title}</h2>
		<div class="about__text">
			{site.about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
		</div>
	</div>
</section>

<style>
	.hero {
		padding-top: clamp(1.5rem, 5vw, 3.5rem);
		padding-bottom: clamp(2rem, 5vw, 3rem);
	}

	.hero__grid {
		display: grid;
		gap: 2.5rem;
		align-items: center;
	}

	.hero__badge {
		margin-bottom: 1.1rem;
	}

	.hero__badge-dot {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 50%;
		background: var(--color-accent);
		flex-shrink: 0;
	}

	.hero__sub {
		font-size: clamp(1.05rem, 2vw, 1.2rem);
		color: var(--color-muted);
		max-width: 34rem;
		line-height: 1.6;
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.75rem;
	}

	.hero__visual {
		position: relative;
		min-height: 16rem;
	}

	.hero__photo {
		overflow: hidden;
	}

	.hero__photo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.hero__photo--main {
		width: min(100%, 26rem);
		aspect-ratio: 4 / 3;
		margin-inline: auto;
		box-shadow: var(--shadow);
	}

	.hero__photo--accent {
		position: absolute;
		right: 0;
		bottom: -1.25rem;
		width: min(52%, 14rem);
		aspect-ratio: 4 / 3;
		border: 3px solid var(--color-bg);
		box-shadow: var(--shadow-sm);
	}

	.hero__glow {
		position: absolute;
		inset: 10% 5% auto;
		height: 70%;
		border-radius: 50%;
		background: radial-gradient(ellipse, rgba(196, 165, 116, 0.28) 0%, transparent 70%);
		z-index: -1;
		pointer-events: none;
	}

	.about {
		padding-top: 0;
		padding-bottom: clamp(2.5rem, 6vw, 4rem);
	}

	.about__inner {
		position: relative;
		max-width: 46rem;
		margin-inline: auto;
		padding: clamp(1.75rem, 4vw, 2.5rem) clamp(1.5rem, 4vw, 2.5rem);
		padding-left: clamp(1.75rem, 4vw, 2.75rem);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		box-shadow: var(--shadow-sm);
	}

	.about__inner::before {
		content: '';
		position: absolute;
		left: 0;
		top: 1.5rem;
		bottom: 1.5rem;
		width: 4px;
		border-radius: 999px;
		background: linear-gradient(180deg, var(--color-wheat), var(--color-accent));
	}

	.about__eyebrow {
		margin: 0 0 0.5rem;
		font-size: 1.35rem;
		line-height: 1;
	}

	.about__text p:last-child {
		margin-bottom: 0;
	}

	@media (min-width: 900px) {
		.hero__grid {
			grid-template-columns: 1.05fr 0.95fr;
			gap: 3rem;
		}

		.hero__visual {
			min-height: 20rem;
		}

		.hero__photo--main {
			margin-inline: 0 2rem;
		}

		.hero__photo--accent {
			right: 0;
			bottom: -1.5rem;
			width: min(48%, 13rem);
		}
	}

	@media (max-width: 540px) {
		.hero__photo--accent {
			right: 0.5rem;
			width: min(55%, 11rem);
			bottom: -1rem;
		}
	}
</style>
